# Copy this file to .env and fill in the values.
# Do NOT commit .env — it is git-ignored.
# For production, set these via Vercel Environment Variables
# (https://vercel.com/<team>/<project>/settings/environment-variables)
# instead of relying on this file in the deployment source.

# Naver Clova Speech API
CLOVA_SPEECH_INVOKE_URL=
CLOVA_SPEECH_SECRET_KEY=

# Google Gemini API
GEMINI_API_KEY=

# Notion API
NOTION_DATABASE_ID=
NOTION_TOKEN=
